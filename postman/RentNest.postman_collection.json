{
  "info": {
    "name": "RentNest API",
    "description": "Postman collection for the RentNest rental marketplace backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "tenantToken", "value": "" },
    { "key": "landlordToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "propertyId", "value": "" },
    { "key": "rentalId", "value": "" },
    { "key": "paymentId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Tenant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Tenant\",\n  \"email\": \"newtenant@rentnest.com\",\n  \"password\": \"Tenant@12345\",\n  \"role\": \"TENANT\",\n  \"phone\": \"+8801000000099\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login Tenant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tenant@rentnest.com\",\n  \"password\": \"Tenant@12345\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login Landlord",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"landlord@rentnest.com\",\n  \"password\": \"Landlord@12345\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@rentnest.com\",\n  \"password\": \"Admin@12345\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Tenant Name\",\n  \"phone\": \"+8801000000100\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Properties",
      "item": [
        {
          "name": "Get All Properties",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/properties?location=Dhaka&minPrice=500&maxPrice=2000&page=1&limit=10"
          }
        },
        {
          "name": "Get Property By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/properties/{{propertyId}}"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories"
          }
        },
        {
          "name": "Create Category (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Villa\",\n  \"description\": \"Luxury villas\"\n}"
            },
            "url": "{{baseUrl}}/api/categories"
          }
        }
      ]
    },
    {
      "name": "Landlord",
      "item": [
        {
          "name": "Create Property",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Luxury Flat\",\n  \"description\": \"Spacious flat with city view\",\n  \"location\": \"Dhaka, Bangladesh\",\n  \"price\": 1500,\n  \"bedrooms\": 3,\n  \"bathrooms\": 2,\n  \"amenities\": [\"wifi\", \"parking\"],\n  \"categoryId\": \"replace-with-category-id\"\n}"
            },
            "url": "{{baseUrl}}/api/landlord/properties"
          }
        },
        {
          "name": "Update Property",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 1600,\n  \"isAvailable\": true\n}"
            },
            "url": "{{baseUrl}}/api/landlord/properties/{{propertyId}}"
          }
        },
        {
          "name": "Delete Property",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlordToken}}" }],
            "url": "{{baseUrl}}/api/landlord/properties/{{propertyId}}"
          }
        },
        {
          "name": "Get Landlord Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlordToken}}" }],
            "url": "{{baseUrl}}/api/landlord/requests"
          }
        },
        {
          "name": "Approve Rental Request",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\"\n}"
            },
            "url": "{{baseUrl}}/api/landlord/requests/{{rentalId}}"
          }
        }
      ]
    },
    {
      "name": "Rentals",
      "item": [
        {
          "name": "Create Rental Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"{{propertyId}}\",\n  \"moveInDate\": \"2026-10-01\",\n  \"message\": \"I would like to rent this property.\"\n}"
            },
            "url": "{{baseUrl}}/api/rentals"
          }
        },
        {
          "name": "Get My Rentals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/api/rentals"
          }
        },
        {
          "name": "Get Rental By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/api/rentals/{{rentalId}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalRequestId\": \"{{rentalId}}\",\n  \"provider\": \"STRIPE\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/create"
          }
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalRequestId\": \"{{rentalId}}\",\n  \"transactionId\": \"pi_test_transaction\",\n  \"provider\": \"STRIPE\",\n  \"paymentIntentId\": \"pi_test_transaction\"\n}"
            },
            "url": "{{baseUrl}}/api/payments/confirm"
          }
        },
        {
          "name": "Get Payment History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/api/payments"
          }
        },
        {
          "name": "Get Payment By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/api/payments/{{paymentId}}"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"{{propertyId}}\",\n  \"rating\": 5,\n  \"comment\": \"Excellent property and landlord support.\"\n}"
            },
            "url": "{{baseUrl}}/api/reviews"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "Ban User",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isDeleted\": true\n}"
            },
            "url": "{{baseUrl}}/api/admin/users/{{userId}}"
          }
        },
        {
          "name": "Get All Properties",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/properties"
          }
        },
        {
          "name": "Get All Rentals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/admin/rentals"
          }
        }
      ]
    }
  ]
}
